# bucket.foundation — reference site env
# Copy this file to .env.local and fill in values.
# Never commit .env.local.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (auth + user data, optional for protocol) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Dynamic (wallet auth, optional) ---
# Code reads NEXT_PUBLIC_DYNAMIC_ENV_ID. When unset, Web3Providers renders bare
# and wallet-gated pages fall back to a read-only ready state.
NEXT_PUBLIC_DYNAMIC_ENV_ID=
# Legacy alias kept for older tooling.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# --- Story Protocol (IP mint, optional) ---
STORY_RPC_URL=
STORY_PRIVATE_KEY=
STORY_SPG_NFT_COLLECTION=

# --- Walrus (storage, optional) ---
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=

# --- Pinata (IPFS pin, optional) ---
PINATA_JWT=

# --- x402 buyer wallet (required for pay-once-cite-forever flow) ---
# This wallet pays for papers via x402 and receives citation fees.
X402_BUYER_PRIVATE_KEY=
X402_NETWORK=base
X402_DEFAULT_PAYOUT_WALLET=

# --- x402 research gateway (optional upstream source) ---
X402_RESEARCH_GATEWAY_URL=

# --- Kruse Index private preview (bkt-002 / bkt-003) ---
# HS256 signing secret for tokenized access cookies. Must be >=32 chars.
# Generate with: openssl rand -base64 48
# SOURCE OF TRUTH IN PROD IS VERCEL ENV VARS — do NOT commit a real value here.
BKT_KRUSE_TOKEN_SECRET=
# Bump this integer to revoke ALL outstanding tokens at once.
BKT_KRUSE_TOKEN_VERSION=1
# Comma-separated allow-list of recipient IDs.
BKT_KRUSE_ALLOWED_RECIPIENTS=kruse
# Upstream Kruse Index server (local dev default: the FTS5 + MiniLM server at ~/jackkruse).
# Production: point at the feed402 wrapper once bkt-005 ships.
KRUSE_INDEX_URL=http://localhost:8765

# --- Permanence layer (EAS + Arweave/Irys dual-write) — feature-flagged ---
# When true, /api/research dual-writes successful envelopes to EAS on Base +
# Arweave via Irys. OFF by default. See docs/PERMANENCE_LAYER.md.
BUCKET_PERMANENCE_ENABLED=false
# Shared with x402 buyer when convenient; must be funded on the target chain.
BUCKET_WALLET_PRIVATE_KEY=
# EAS canonical predeploy on Base mainnet + Base Sepolia.
EAS_CONTRACT_BASE=0x4200000000000000000000000000000000000021
EAS_SCHEMA_REGISTRY=0x4200000000000000000000000000000000000020
# Run scripts/register-eas-schema.ts once; paste the resulting UID here.
EAS_SCHEMA_UID=
# "base" | "base-sepolia"
EAS_CHAIN=base-sepolia
# Irys (Arweave bundler). Devnet for dev/test, node1 for mainnet.
IRYS_NODE_URL=https://devnet.irys.xyz
# Token identifier recognized by @irys/sdk (e.g. "base-eth", "ethereum").
IRYS_TOKEN=base-eth
