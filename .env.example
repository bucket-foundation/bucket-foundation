# bucket.foundation — reference site env
# Copy this file to .env.local and fill in values.
# Never commit .env.local.

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (auth + user data, optional for protocol) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Dynamic (wallet auth, optional) ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# --- Story Protocol (IP mint, optional) ---
STORY_RPC_URL=
STORY_PRIVATE_KEY=
STORY_SPG_NFT_COLLECTION=

# --- Walrus (storage, optional) ---
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=

# --- Pinata (IPFS pin, optional) ---
PINATA_JWT=

# --- x402 buyer wallet (required for pay-once-cite-forever flow) ---
# This wallet pays for papers via x402 and receives citation fees.
X402_BUYER_PRIVATE_KEY=
X402_NETWORK=base
X402_DEFAULT_PAYOUT_WALLET=

# --- x402 research gateway (optional upstream source) ---
X402_RESEARCH_GATEWAY_URL=
